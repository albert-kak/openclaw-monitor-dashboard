# Copy this file to .env and adjust the paths for your machine.

OPENCLAW_HOME=/Users/yourname/.openclaw-dev
OPENCLAW_CONFIG_PATH=/Users/yourname/.openclaw-dev/openclaw.json
OPENCLAW_AGENTS_DIR=/Users/yourname/.openclaw-dev/agents
OPENCLAW_LOGS_DIR=/Users/yourname/.openclaw-dev/logs
OPENCLAW_CRON_JOBS_PATH=/Users/yourname/.openclaw-dev/cron/jobs.json
OPENCLAW_SKILLS_DIR=/Users/yourname/.openclaw-dev/skills
OPENCLAW_GATEWAY_LOG_PATH=/Users/yourname/.openclaw-dev/logs/gateway.log
OPENCLAW_GATEWAY_ERROR_LOG_PATH=/Users/yourname/.openclaw-dev/logs/gateway.err.log

# Optional: override ocd daemon state directory (default: <repo>/.ocd)
# OCD_STATE_DIR=/path/to/ocd-state
